{
  "expo": {
    "name": "Interview Station",
    "slug": "interview-station",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7F3EE"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.interviewstation.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F1E3D"
      },
      "package": "com.interviewstation.app"
    },
    "scheme": "interview-station",
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
